{
  "name": "stash",
  "version": "1.3.0",
  "description": "Your prompt library",
  "main": "main.js",
  "scripts": {
    "dev": "node dev.js",
    "start": "electron .",
    "web": "vite",
    "build:web": "vite build",
    "build:win": "pnpm build:web && electron-builder --win --publish never",
    "build:mac": "pnpm build:web && electron-builder --mac --publish never",
    "build:linux": "pnpm build:web && electron-builder --linux --publish never"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^30.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^8.0.14",
    "vite-plugin-pwa": "^1.3.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  },
  "build": {
    "appId": "com.stash.promptlibrary",
    "productName": "Stash",
    "files": [
      "dist-web/**",
      "companion.html",
      "companion.js",
      "companion.css",
      "settings.html",
      "settings.js",
      "settings.css",
      "main.js",
      "public/**"
    ],
    "win": {
      "icon": "public/logo.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "public/logo.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "icon": "public/logo.png",
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
